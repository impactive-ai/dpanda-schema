{
  "$id": "https://impactive-ai.com/schemas/dpanda/dataset/dataset-v1.2.0.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DPanda Dataset",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": ["string", "null"]
    },
    "by": {
      "type": "string",
      "enum": ["COLUMNSPEC", "INTERNAL", "JSONSCHEMA"]
    },
    "type": {
      "type": "string",
      "enum": ["METADATA", "EVENT", "PREDICTION", "SHAP"]
    },
    "bunchId": {
      "type": "string",
      "description": "데이터셋 묶음 정의. 변경 감지 및 이벤트 트리거링시 사용"
    },
    "useDb": {
      "type": ["boolean", "null"],
      "description": "DB에 저장 여부",
      "default": false
    },
    "tenantVisible": {
      "type": ["boolean", "null"],
      "description": "테넌트 노출 여부",
      "default": false
    },
    "freq": {
      "type": "string",
      "enum": ["D", "W", "M"],
      "description": "데이터 발생 주기"
    },
    "partition": {
      "type": "string",
      "enum": ["D", "W", "M"],
      "description": "파티셔닝 주기"
    },
    "grainColumns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "refDateColumn": {
      "type": "string"
    },
    "jsonSchema": {
      "$ref": "http://json-schema.org/draft-07/schema#"
    },
    "columnSpecs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "column": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "DATE",
              "TIMESTAMP",
              "INT",
              "STRING",
              "FLOAT",
              "NUMERIC",
              "DOUBLE"
            ]
          },
          "desc": {
            "type": ["string", "null"]
          },
          "nullable": {
            "type": ["boolean", "null"],
            "default": false
          }
        },
        "required": ["column", "type"],
        "additionalProperties": false
      }
    }
  },
  "required": ["name", "by", "type", "bunchId"],
  "additionalProperties": false
}
